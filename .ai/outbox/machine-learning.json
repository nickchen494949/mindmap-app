{
  "nodes": [
    {
      "id": 1,
      "x": 610,
      "y": 80,
      "label": "机器学习",
      "desc": "让计算机通过分析历史数据自己寻找规律，从而对未来的新情况做出预测或决策，而不是靠人手工编写固定规则。",
      "bg": "#eff6ff",
      "border": "#2563eb",
      "nw": 260,
      "showDesc": true
    },
    {
      "id": 2,
      "x": 150,
      "y": 250,
      "label": "解决什么问题",
      "desc": "机器学习主要帮我们处理那些规则太复杂、人脑数不过来的实际难题。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 3,
      "x": 150,
      "y": 400,
      "label": "从数据找规律",
      "desc": "像人一样从大量经历（数据）中总结经验，找出隐藏的关系 and 模式。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 4,
      "x": 150,
      "y": 550,
      "label": "预测数值与分类",
      "desc": "比如预测明天的气温是多少度（回归），或者判断一张图片里是猫还是狗（分类）。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 5,
      "x": 150,
      "y": 700,
      "label": "寻找相似群体",
      "desc": "在没有标签的情况下，自动把相似的人或事物聚成一类，比如划分不同的客户群体。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 6,
      "x": 150,
      "y": 850,
      "label": "连续做出决策",
      "desc": "像下棋或开自动驾驶汽车一样，需要在不断变化的环境中，连续做出一连串决定以达成目标。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 7,
      "x": 400,
      "y": 250,
      "label": "核心学习流程",
      "desc": "要把机器学习跑通，通常需要像工厂流水线一样按部就班地完成几个关键步骤。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 8,
      "x": 400,
      "y": 400,
      "label": "收集数据与选特征",
      "desc": "垃圾进垃圾出，必须先准备干净的数据，并挑出对预测最有帮助的因素（特征）。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 9,
      "x": 400,
      "y": 550,
      "label": "训练与验证模型",
      "desc": "让算法在数据中尝试寻找规律（训练），并用一部分预留的数据检查它找的规律准不准（验证）。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 10,
      "x": 400,
      "y": 700,
      "label": "样本外测试",
      "desc": "必须用模型从来没见过的新数据做最终测试，防止模型只是把历史答案死记硬背下来。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 11,
      "x": 400,
      "y": 850,
      "label": "上线预测与迭代",
      "desc": "把模型投入实际使用去预测新数据，并定期观察它的实际表现，不断用新数据更新它。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 12,
      "x": 650,
      "y": 250,
      "label": "主要实现方法",
      "desc": "根据不同任务，科学家们发明了各种不同的数学工具来建立模型。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 13,
      "x": 650,
      "y": 400,
      "label": "回归与分类算法",
      "desc": "最基础的数学方法，比如画一条直线拟合趋势（回归），或者划一条分界线区分不同类别（分类）。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 14,
      "x": 650,
      "y": 550,
      "label": "聚类分析",
      "desc": "不需要正确答案，通过计算个体之间的相似度，自动把相似的数据聚成一团。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 15,
      "x": 650,
      "y": 700,
      "label": "树模型与神经网络",
      "desc": "树模型像做选择题（决策树/随机森林）；神经网络则模仿人脑连接方式，适合处理复杂的图像与文字。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 16,
      "x": 650,
      "y": 850,
      "label": "强化学习",
      "desc": "通过「尝试-犯错-获得奖惩」的循环来学习，像训练宠物一样，让机器学会在环境中如何行动。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 17,
      "x": 900,
      "y": 250,
      "label": "防止自欺欺人",
      "desc": "机器学习最容易犯的错误是‘假装学得很好’，这需要极其严格的防范措施。",
      "bg": "#fef2f2",
      "border": "#dc2626",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 18,
      "x": 900,
      "y": 400,
      "label": "过拟合与样本内陷阱",
      "desc": "模型太聪明以至于把训练数据里的噪声和偶然因素也背下来了，结果在历史数据里得满分，遇到新数据就零分。",
      "bg": "#fef2f2",
      "border": "#dc2626",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 19,
      "x": 900,
      "y": 550,
      "label": "数据泄露",
      "desc": "在训练模型时，不小心把未来的信息或不该知道的答案掺和了进去，导致测试成绩虚高。",
      "bg": "#fef2f2",
      "border": "#dc2626",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 20,
      "x": 900,
      "y": 700,
      "label": "基准模型",
      "desc": "永远要跟最简单的规则（比如掷硬币或历史均值）对比。如果费尽心机的复杂模型连简单规则都打不过，就是失败的。",
      "bg": "#fef2f2",
      "border": "#dc2626",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 21,
      "x": 900,
      "y": 850,
      "label": "前向测试",
      "desc": "在时间轴上，永远只用历史数据训练，用未来的数据测试，绝不能穿越时空看答案。",
      "bg": "#fef2f2",
      "border": "#dc2626",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 22,
      "x": 1150,
      "y": 250,
      "label": "现实生活用途",
      "desc": "机器学习早已融入我们的衣食住行和工作决策中。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 23,
      "x": 1150,
      "y": 400,
      "label": "量化投资策略",
      "desc": "通过分析历史行情和财务数据，自动寻找买卖时机，构建能战胜市场的投资组合。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 24,
      "x": 1150,
      "y": 550,
      "label": "推荐与风控",
      "desc": "像抖音/淘宝推荐你喜欢的内容，以及银行判断一笔交易是否是信用卡盗刷。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 180,
      "showDesc": true
    },
    {
      "id": 25,
      "x": 1150,
      "y": 700,
      "label": "视觉与语言理解",
      "desc": "人脸识别、自动驾驶看红绿灯，以及像 ChatGPT 那样理解人类的提问并流利对话。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 180,
      "showDesc": true
    }
  ],
