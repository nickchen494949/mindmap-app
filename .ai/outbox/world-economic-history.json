{
  "nodes": [
    {
      "id": 1,
      "x": 1825,
      "y": 80,
      "label": "世界经济史",
      "desc": "揭示人类如何打破土地和人力的生存限制，跃升至由能源、技术、金融与制度驱动的现代化世界。",
      "bg": "#f8fafc",
      "border": "#475569",
      "nw": 260,
      "showDesc": true
    },
    {
      "id": 2,
      "x": 250,
      "y": 250,
      "label": "长期底层逻辑",
      "desc": "经济增长的核心在于生产率（人均产出）。它由五大要素螺旋驱动：能源、制度、贸易、分配与技术。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 3,
      "x": 140,
      "y": 400,
      "label": "生产力与能源动力",
      "desc": "生产力决定了人均产出。人类历史上每一次大跃进，本质上都是能源载体的突破（木柴/牲畜 -> 煤炭/蒸汽 -> 石油/电力 -> 算力/数据）。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 4,
      "x": 360,
      "y": 400,
      "label": "制度、网络与分配",
      "desc": "产权保护和国家能力提供安全底线，贸易网络决定财富流向，而分配冲突（谁分到蛋糕）决定了系统的长期稳定性与可持续消费能力。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 5,
      "x": 700,
      "y": 250,
      "label": "前工业时代",
      "desc": "工业革命前的漫长岁月，人类社会处于超低速增长状态，整体生活水平挣扎在生存线边缘。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 6,
      "x": 590,
      "y": 400,
      "label": "马尔萨斯陷阱",
      "desc": "核心矛盾是有限的土地无法支撑无限的人口。技术微小进步带来的财富增加，很快被人口增长稀释，人均生活水平重回温饱线。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 7,
      "x": 810,
      "y": 400,
      "label": "局部繁荣与技术瓶颈",
      "desc": "虽然有局部的古代城市繁荣与丝绸之路等奢侈品贸易，但由于科学尚未与生产结合，生产经验难以代际积累，无法突破农业底色。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 8,
      "x": 1150,
      "y": 250,
      "label": "工业革命与大分流",
      "desc": "18世纪中叶起，西欧率先实现能源和机器生产的突破，彻底挣脱了土地对人类的约束。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 9,
      "x": 1030,
      "y": 400,
      "label": "煤炭、蒸汽机与工厂",
      "desc": "化石能源（煤炭）打破了生物能的物理上限。工厂制度通过极细的分工，使劳动效率呈几何级数增长，实现了生产力的指数级爆发。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 10,
      "x": 1270,
      "y": 400,
      "label": "专利产权与资本市场",
      "desc": "英国等国确立的私有产权与专利法保护了发明收益，而股份公司和发达的债券市场大幅降低了高风险科技投资的融资门槛。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 11,
      "x": 1150,
      "y": 550,
      "label": "掠夺市场与大分流",
      "desc": "工业国利用殖民扩张攫取廉价原料并倾销商品。率先完成工业化的西方国家迅速暴富，而未工业化的传统文明逐步边缘化，拉开世界贫富巨幅差距。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 12,
      "x": 1600,
      "y": 250,
      "label": "第一轮全球化",
      "desc": "伴随技术红利与帝国秩序，世界在19世纪末被紧密编织进以欧洲为中心的单一贸易网中。",
      "bg": "#fff1f2",
      "border": "#e11d48",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 13,
      "x": 1480,
      "y": 400,
      "label": "蒸汽船、铁路与电报",
      "desc": "交通工具使跨洋运输成本断崖式下跌，电报让信息跨国秒级传递，大宗商品和金融市场首次实现了全球实时同步。",
      "bg": "#fff1f2",
      "border": "#e11d48",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 14,
      "x": 1720,
      "y": 400,
      "label": "金本位与资本/劳工流动",
      "desc": "以黄金为锚的固定汇率体系消除了汇率风险，巨量资本在伦敦、纽约调度下流向新兴市场，数千万劳工跨大洋自由迁移。",
      "bg": "#fff1f2",
      "border": "#e11d48",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 15,
      "x": 1600,
      "y": 550,
      "label": "帝国体系与不平等交换",
      "desc": "欧洲列强用军舰与不平等条约保障资本和贸易通道安全。虽然全球生产总量激增，但财富与定价权高度向宗主国集中。",
      "bg": "#fff1f2",
      "border": "#e11d48",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 16,
      "x": 2050,
      "y": 250,
      "label": "崩塌与重建",
      "desc": "两次世界大战与大萧条摧毁了互信，全球化在政治撕裂中走向崩溃，战后在废墟上以美苏对抗的阵营化形式艰难重组。",
      "bg": "#f0f9ff",
      "border": "#0284c7",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 17,
      "x": 1930,
      "y": 400,
      "label": "战争、大萧条与关税壁垒",
      "desc": "1914年后欧洲大打出手，信用和债务链崩断。1929年大萧条引爆恶性关税战，各国退回排他性经济阵营，金本位彻底土崩瓦解。",
      "bg": "#f0f9ff",
      "border": "#0284c7",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 18,
      "x": 2170,
      "y": 400,
      "label": "布雷顿森林体系三大支柱",
      "desc": "1944年确立了IMF（短期资助）、世界银行（长期重建）与关贸总协定（GATT，减税），用制度化协作替代过去的无序混乱。",
      "bg": "#f0f9ff",
      "border": "#0284c7",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 19,
      "x": 2050,
      "y": 550,
      "label": "美元霸权与阵营化经济",
      "desc": "确立“美元挂钩黄金、其他货币挂钩美元”的秩序，美国输出流动性重建欧洲。但在冷战阴影下，世界分裂为东西方两大互不来往的经济圈。",
      "bg": "#f0f9ff",
      "border": "#0284c7",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 20,
      "x": 2500,
      "y": 250,
      "label": "新自由主义全球化",
      "desc": "随着冷战结束与管制放开，以追求极致效率和跨国公司拼图式生产为特征的全球化迎来高潮。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 21,
      "x": 2380,
      "y": 400,
      "label": "金融自由化与IT革命",
      "desc": "各国拆除资本流动防火墙，跨国资本如洪流般涌动；互联网和个人电脑让全球总部对异地供应链的即时控制与精细协同成为现实。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 22,
      "x": 2620,
      "y": 400,
      "label": "集装箱运输与供应链分工",
      "desc": "集装箱极大压缩了运输成本，生产环节被切碎到不同国家。一件商品在A国设计，B国造零件，C国组装，世界变为一条流水线。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 23,
      "x": 2500,
      "y": 550,
      "label": "中国开放与低通胀红利",
      "desc": "中国等新兴市场并入全球体系，提供源源不断的廉价高素质劳动力。这为西方带来长达二十年的低通胀生活与资产价格暴涨。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 24,
      "x": 2950,
      "y": 250,
      "label": "当代新阶段",
      "desc": "单纯追求效率的全球化已触及政治与安全的极限，地缘回归、债务承压与技术革命正在重塑游戏规则。",
      "bg": "#fff7ed",
      "border": "#ea580c",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 25,
      "x": 2830,
      "y": 400,
      "label": "债务高企与安全重于效率",
      "desc": "2008年次贷危机后，各国靠量化宽松印钞续命，积累了历史性的债务。供应链开始从“离岸外包”转向“近岸与友岸备份”，安全考量压倒成本优势。",
      "bg": "#fff7ed",
      "border": "#ea580c",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 26,
      "x": 3070,
      "y": 400,
      "label": "中国产业升级与能源转型",
      "desc": "中国从产业链底端走向中高端，在绿色低碳（新能源、电池、电动车）领域取得领先，引发欧美等国筑墙实施贸易保护。",
      "bg": "#fff7ed",
      "border": "#ea580c",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 27,
      "x": 2950,
      "y": 550,
      "label": "地缘对抗与AI生产力变革",
      "desc": "地缘冲突破坏了大国间的商业互信，脱钩断链频发；同时，以生成式AI为代表的数字化革命，正尝试重塑未来的脑力分工与劳动格局。",
      "bg": "#fff7ed",
      "border": "#ea580c",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 28,
      "x": 3400,
      "y": 250,
      "label": "历史的现实应用",
      "desc": "历史是未来的透镜。理解经济运行的几大支柱变化，是做宏观决策和投资配置的科学检验清单。",
      "bg": "#f0fdfa",
      "border": "#0d9488",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 29,
      "x": 3280,
      "y": 400,
      "label": "宏观基本面检查（能与钱）",
      "desc": "第一看能源成本：每次繁荣都建立在廉价能源上；第二看金融环境：关注全球利率与负债状况，它们决定了商业扩张的血液是否充足。",
      "bg": "#f0fdfa",
      "border": "#0d9488",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 30,
      "x": 3520,
      "y": 400,
      "label": "贸易秩序与国家能力（制度）",
      "desc": "第三看国际贸易规则：是壁垒重重还是自由流通？第四看国家治理：这决定了一个国家是提供良性的营商环境还是低效行政阻碍。",
      "bg": "#f0fdfa",
      "border": "#0d9488",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 31,
      "x": 3400,
      "y": 550,
      "label": "技术扩散与分配冲突（变数）",
      "desc": "第五看关键技术的垄断还是加速扩散；第六看贫富分化与民粹主义：分配不均往往是引发规则洗牌和地缘动荡的最底层火药桶。",
      "bg": "#f0fdfa",
      "border": "#0d9488",
      "nw": 200,
      "showDesc": true
    }
  ],
