{
  "nodes": [
    {
      "id": 1,
      "x": 750,
      "y": 80,
      "label": "世界经济史",
      "desc": "解释人类经济如何从土地和人力驱动，变成能源、机器、金融、全球贸易、科技和制度驱动。",
      "bg": "#f8fafc",
      "border": "#475569",
      "nw": 240,
      "showDesc": true
    },
    {
      "id": 2,
      "x": 150,
      "y": 280,
      "label": "底层驱动力",
      "desc": "推动经济长期增长的核心轮子，决定了财富创造的效率边界和可持续性。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 7,
      "x": 150,
      "y": 440,
      "label": "生产力",
      "desc": "人均产出决定生活水平，是衡量一切增长的终极硬指标。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 8,
      "x": 150,
      "y": 600,
      "label": "制度与产权",
      "desc": "稳定的私有产权与专利制度，让长期投资和技术发明免受暴力剥夺的威胁。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 9,
      "x": 150,
      "y": 760,
      "label": "能源革命",
      "desc": "从煤炭到石油、电力，高密度能源革命彻底打破了生物能的物理上限。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 10,
      "x": 150,
      "y": 920,
      "label": "金融体系",
      "desc": "通过信用扩张、跨期配置资源 and 风险共担，为大规模商业提供资金地基。",
      "bg": "#f5f3ff",
      "border": "#7c3aed",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 3,
      "x": 450,
      "y": 280,
      "label": "关键转折点",
      "desc": "重塑人类历史轨迹的历史事件，将全球经济带入全新的发展范式。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 11,
      "x": 450,
      "y": 440,
      "label": "大航海时代",
      "desc": "打通全球航线，开启大范围商品与资本流动，奠定早期全球化和殖民贸易的基础。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 12,
      "x": 450,
      "y": 600,
      "label": "工业革命",
      "desc": "机器化工厂取代手工作坊，煤炭蒸汽打破土地约束，生产力实现指数级爆发。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 13,
      "x": 450,
      "y": 760,
      "label": "布雷顿森林",
      "desc": "1944年确立了以美元为核心的国际货币秩序，将美元与黄金挂钩，其他货币挂钩美元。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 14,
      "x": 450,
      "y": 920,
      "label": "全球化浪潮",
      "desc": "以世贸组织（WTO）和全球供应链为核心，实现跨国产业分工与效率最大化。",
      "bg": "#ecfdf5",
      "border": "#059669",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 4,
      "x": 750,
      "y": 280,
      "label": "经济体系演变",
      "desc": "人类主导经济形态的历史嬗变，折射出底层技术和生产关系的不断升级。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 15,
      "x": 750,
      "y": 440,
      "label": "农业经济",
      "desc": "以土地为最核心生产资料，靠人力 and 牲畜劳作，产出高度受自然环境制约。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 16,
      "x": 750,
      "y": 600,
      "label": "工业经济",
      "desc": "以能源革命和工厂制度为核心，机械化批量生产取代了手工劳动，财富爆发式增长。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 17,
      "x": 750,
      "y": 760,
      "label": "金融资本主义",
      "desc": "经济重心从实业制造转向金融中介，资本跨境自由流动，资产价格与负债成为核心驱动。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 18,
      "x": 750,
      "y": 920,
      "label": "数字经济",
      "desc": "以计算机、互联网和人工智能（AI）为核心，数据成为新型生产要素，边际成本接近于零。",
      "bg": "#fffbeb",
      "border": "#d97706",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 5,
      "x": 1050,
      "y": 280,
      "label": "危机与教训",
      "desc": "在系统失衡或外部冲击时爆发的剧烈波动，提供了防范系统性风险的惨痛教训。",
      "bg": "#fff1f2",
      "border": "#e11d48",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 19,
      "x": 1050,
      "y": 440,
      "label": "大萧条",
      "desc": "1929年美国股灾引爆全球信用崩盘，大范围通缩与失业导致社会秩序严重撕裂。",
      "bg": "#fff1f2",
      "border": "#e11d48",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 20,
      "x": 1050,
      "y": 600,
      "label": "石油危机",
      "desc": "1970年代地缘政治引爆油价飙升，导致西方世界陷入长期滞胀，终结了战后黄金增长期。",
      "bg": "#fff1f2",
      "border": "#e11d48",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 21,
      "x": 1050,
      "y": 760,
      "label": "金融海啸",
      "desc": "2008年美国次贷危机引爆全球债务链条崩断，宣告新自由主义无限扩张阶段的终结。",
      "bg": "#fff1f2",
      "border": "#e11d48",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 22,
      "x": 1050,
      "y": 920,
      "label": "疫情冲击",
      "desc": "突发公共卫生事件阻断全球供应链，引发大规模政府救市 and 高通胀，重塑效率与安全的平衡。",
      "bg": "#fff1f2",
      "border": "#e11d48",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 6,
      "x": 1350,
      "y": 280,
      "label": "对你的启示",
      "desc": "从浩瀚历史中抽离出的底层规律，为我们理解当下、看清未来大趋势提供认知坐标系。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 23,
      "x": 1350,
      "y": 440,
      "label": "周期必然存在",
      "desc": "繁荣与萧条交替是经济的客观规律，必须在繁荣期为萧条期做好安全防线。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 24,
      "x": 1350,
      "y": 600,
      "label": "杠杆是双刃剑",
      "desc": "债务能放大收益但也会放大风险，过度信用扩张是所有重大金融危机的根源。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 25,
      "x": 1350,
      "y": 760,
      "label": "制度决定繁荣",
      "desc": "只有保护产权和鼓励创新的稳定法治环境，才能激发长期投资 and 持续的经济繁荣。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 200,
      "showDesc": true
    },
    {
      "id": 26,
      "x": 1350,
      "y": 920,
      "label": "技术改变规则",
      "desc": "每一次生产力突破都会重塑分工与利益格局，唯有主动拥抱技术变革者才能免遭淘汰。",
      "bg": "#ecfeff",
      "border": "#0891b2",
      "nw": 200,
      "showDesc": true
    }
  ],
